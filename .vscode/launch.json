{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "prefect_flow.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/prefect_flow.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "prefect_deploy_flow",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/prefect_deploy_flow.py",
            "cwd": "${workspaceFolder}/src",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "run_optimizer_flow_function",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/local_test/run_optimizer_flow_function.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}